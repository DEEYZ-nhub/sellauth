<nav
  class="component navbar"
  data-component-id="navbar"
  x-data="{
    isCollapsed: true,
    menuHeight: 0,
    scrolled: false,
    init() {
      window.addEventListener('scroll', () => {
        this.scrolled = window.scrollY > 20;
      });
    }
  }"
>
  <div class="sticky top-0 z-40 transition-all duration-300" :class="scrolled ? 'bg-background/95 backdrop-blur-xl border-b border-white/[0.06]' : 'bg-transparent'">
    <div class="flex items-center justify-between w-full px-4 py-4 lg:px-8 lg:py-5">
      <div class="flex items-center">
        {% if global.components.navbar.show_logo or global.components.navbar.show_shop_name %}
          <a href="{{ '/' | shopUrl }}" class="flex items-center gap-3">
            {% if global.components.navbar.show_logo and shop.image_url %}
              <img
                src="{{ shop.image_url }}"
                alt="{{ shop.name }}"
                class="max-h-8 lg:max-h-9"
              />
            {% endif %}
            {% if global.components.navbar.show_shop_name %}
              <h1 class="text-t-primary text-lg lg:text-xl font-semibold tracking-tight">{{ shop.name }}</h1>
            {% endif %}
          </a>
        {% endif %}
      </div>

      <div class="hidden lg:flex items-center gap-1">
        {% for link in global.components.navbar.links %}
        {% set lActive = false %}
        {% if (link.link == '/' and templateName == 'shop') or (link.link == '/cart' and templateName == 'cart') or (link.link == '/products' and templateName == 'products') or (link.link == '/terms-of-service' and templateName == 'terms') or (link.link == '/privacy-policy' and templateName == 'privacy-policy') or (link.link == '/refund-policy' and templateName == 'refund-policy') or (link.link == '/feedback' and templateName == 'feedback') or (link.link == '/status' and templateName == 'status') or (link.link == '/faq' and templateName == 'faq') or (link.link == '/blog' and templateName == 'blog') %}
        {% set lActive = true %}
        {% endif %}

        {% if lActive and link.shape == 'regular' %}
        {% set lClass = 'text-t-primary' %}
        {% elif not lActive and link.shape == 'regular' %}
        {% set lClass = 'text-t-primary/50 hover:text-t-primary' %}
        {% elif lActive and link.shape == 'button' %}
        {% set lClass = 'text-t-primary bg-accent-500 hover:bg-accent-600' %}
        {% elif not lActive and link.shape == 'button' %}
        {% set lClass = 'text-t-primary bg-accent-500 hover:bg-accent-600' %}
        {% endif %}

        <a
          href="{{ link.link | shopUrl }}"
          target="{{ '_blank' if link.new_tab }}"
          class="px-4 py-2 whitespace-nowrap text-sm font-medium rounded-lg transition-colors duration-200 {{ lClass }}"
        >
          {{ link.text }}
        </a>
        {% endfor %}
      </div>

      <div class="flex items-center gap-3">
        {% if not global.components.navbar.hide_currency_selector %}
          {% if currency_rates_usd | length > 1 %}
            <div class="currency-selector xs lg:hidden">
              <select class="bg-transparent text-transparent font-semibold" style="width: 78px; height: 40px;">
                {% for code, rate in currency_rates_usd %}
                  <option value="{{ code }}">
                    <span class="flex items-center justify-between">
                      <span>
                        <span class="inline-block w-10 bg-white/5 text-t-primary text-center px-1 py-px mr-1 symbol">{{ currency_symbols[code] }}</span>
                        <span class="text-t-primary code">{{ code.toUpperCase() }}</span>
                      </span>
                      {% if code.toUpperCase() == currency %}
                        <span class="text-t-primary/75 text-xs default">Default</span>
                      {% endif %}
                    </span>
                  </option>
                {% endfor %}
              </select>
            </div>
          {% endif %}
        {% endif %}

        {% if not global.components.navbar.hide_customer_dashboard %}
          {% if shop_customer %}
            <a
              href="{{ '/customer/dashboard' | shopUrl }}"
              class="hidden lg:inline-flex items-center gap-2 px-4 py-2 whitespace-nowrap text-sm font-medium text-t-primary/50 hover:text-t-primary transition-colors duration-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
              Account
            </a>
          {% else %}
            <button
              type="button"
              @click="appCustomer.loginOrRedirect()"
              class="hidden lg:inline-flex items-center gap-2 px-4 py-2 whitespace-nowrap text-sm font-medium text-t-primary/50 hover:text-t-primary transition-colors duration-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
              Login
            </button>
          {% endif %}
        {% endif %}

        {% if not global.components.navbar.hide_currency_selector %}
          {% if currency_rates_usd | length > 1 %}
            <div class="currency-selector lg hidden lg:block">
              <select class="bg-transparent border border-white/[0.08] text-transparent font-semibold rounded-lg" style="width: 80px; height: 40px;">
                {% for code, rate in currency_rates_usd %}
                  <option value="{{ code }}">
                    <span class="flex items-center justify-between">
                      <span>
                        <span class="inline-block w-10 bg-white/5 text-t-primary text-center px-1 py-px mr-1 symbol">{{ currency_symbols[code] }}</span>
                        <span class="text-t-primary code">{{ code.toUpperCase() }}</span>
                      </span>
                      {% if code.toUpperCase() == currency %}
                        <span class="text-t-primary/75 text-xs default">Default</span>
                      {% endif %}
                    </span>
                  </option>
                {% endfor %}
              </select>
            </div>
          {% endif %}
        {% endif %}

        {% if not global.components.navbar.hide_cart %}
          <a href="{{ '/cart' | shopUrl }}" class="inline-flex items-center justify-center size-10 relative text-t-primary/50 rounded-lg transition-all duration-200 hover:text-accent-500 hover:bg-white/[0.04] focus:outline-none">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
            </svg>
            <template x-if="appCart.countWithQuantities > 0">
              <span class="absolute -top-0.5 -right-0.5 inline-flex items-center justify-center size-[1.125rem] bg-accent-500 text-t-primary text-[0.625rem] font-semibold rounded-full">
                <span x-text="appCart.countWithQuantities > 9 ? '9+' : appCart.countWithQuantities"></span>
              </span>
            </template>
          </a>
        {% endif %}

        <button
          type="button" 
          x-on:click="isCollapsed = !isCollapsed; $nextTick(() => menuHeight = isCollapsed ? 0 : $refs.menu.scrollHeight)" 
          class="inline-flex items-center justify-center size-10 text-t-primary/50 rounded-lg transition-all duration-200 lg:hidden hover:text-t-primary hover:bg-white/[0.04] focus:outline-none"
        >
          <svg class="size-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
          </svg>
        </button>
      </div>
    </div>

    <div
      x-ref="menu" 
      class="w-full overflow-hidden lg:overflow-visible transition-all duration-300 ease-in-out lg:hidden lg:!h-auto"
      x-bind:style="{ height: isCollapsed ? '0px' : menuHeight + 'px' }"
      x-cloak
    >
      <div class="flex flex-col gap-1 px-4 pb-6">
        {% for link in global.components.navbar.links %}
        {% set lActive = false %}
        {% if (link.link == '/' and templateName == 'shop') or (link.link == '/cart' and templateName == 'cart') or (link.link == '/products' and templateName == 'products') or (link.link == '/terms-of-service' and templateName == 'terms') or (link.link == '/privacy-policy' and templateName == 'privacy-policy') or (link.link == '/refund-policy' and templateName == 'refund-policy') or (link.link == '/feedback' and templateName == 'feedback') or (link.link == '/status' and templateName == 'status') or (link.link == '/faq' and templateName == 'faq') or (link.link == '/blog' and templateName == 'blog') %}
        {% set lActive = true %}
        {% endif %}

        <a
          href="{{ link.link | shopUrl }}"
          target="{{ '_blank' if link.new_tab }}"
          class="px-4 py-2.5 whitespace-nowrap text-sm font-medium rounded-lg transition-colors duration-200 {{ 'text-t-primary bg-white/[0.04]' if lActive else 'text-t-primary/50 hover:text-t-primary hover:bg-white/[0.02]' }}"
        >
          {{ link.text }}
        </a>
        {% endfor %}

        {% if not global.components.navbar.hide_customer_dashboard %}
          {% if shop_customer %}
            <a
              href="{{ '/customer/dashboard' | shopUrl }}"
              class="px-4 py-2.5 whitespace-nowrap text-sm font-medium text-t-primary/50 hover:text-t-primary rounded-lg transition-colors duration-200"
            >
              My Account
            </a>
          {% else %}
            <button
              type="button"
              @click="appCustomer.loginOrRedirect()"
              class="px-4 py-2.5 whitespace-nowrap text-sm font-medium text-left text-t-primary/50 hover:text-t-primary rounded-lg transition-colors duration-200"
            >
              Login
            </button>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>
</nav>
