<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="py-12 lg:py-16">
    <div class="flex flex-col gap-6 lg:flex-row lg:gap-10">
      <div class="lg:w-3/5">
        <div>
          <div class="bg-white/[0.02] border border-white/[0.06] rounded-xl text-t-primary p-5 md:p-8">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-6">
              <h1 class="flex-1 text-t-primary text-xl font-bold truncate tracking-tight md:text-2xl lg:text-3xl">
                {{ product.name }}
              </h1>
              {% if product.status_color or product.status_text %}
                <div class="flex items-center gap-2.5 status" data-color="{{ product.status_color }}" data-label="{{ product.status_text }}">
                  <div class="relative size-3 rounded-full" style="background-color: {{ product.status_color }}">
                    <div class="pulsating" style="background-color: {{ product.status_color }}"></div>
                  </div>
                  <span class="text-xs font-semibold uppercase tracking-wider" style="color: {{ product.status_color }}">
                    {{ product.status_text }}
                  </span>
                </div>
              {% endif %}
            </div>

            {% if product.category_id or product.product_badges.page|length > 0 %}
              <div class="flex items-center gap-2 flex-wrap mb-6">
                {% if product.category_id %}
                  <a href="{{ product.category.url }}" class="inline-flex items-center gap-1.5 bg-accent-500/10 text-accent-500 text-xs font-semibold px-3 py-1.5 rounded-md transition-colors duration-200 hover:bg-accent-500/20">
                    <i class="fa fa-border-all fa-fw text-[0.6rem]"></i>
                    {{ product.category.name }}
                  </a>
                {% endif %}
                {% for productBadge in product.product_badges.page %}
                  <div class="inline-flex items-center gap-1.5 text-t-accent text-xs font-semibold px-3 py-1.5 rounded-md" style="background-color: {{ productBadge.color }}" data-text="{{ productBadge.label }}" data-color="{{ productBadge.color }}">
                    {% if productBadge.icon %}
                      <i class="{{ productBadge.icon }} fa-fw text-[0.6rem]"></i>
                    {% endif %}
                    {{ productBadge.label }}
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          </div>

          {% if product.image_urls|length > 0 or product.image_url %}
          <div class="mt-4 bg-white/[0.02] border border-white/[0.06] rounded-xl overflow-hidden text-t-primary aspect-product-page-image">
            {% if product.image_urls|length > 0 %}
            <div class="splide main">
              <div class="splide__track aspect-product-page-image">
                <ul class="splide__list">
                  {% for image in product.image_urls %}
                  <li class="splide__slide">
                    <img src="{{ image }}" class="size-full object-product-image" style="{{ 'display: none;' if loop.index > 1 }}" />
                  </li>
                  {% endfor %}
                </ul>
              </div>
            </div>
            {% elif product.image_url %}
            <img src="{{ product.image_url }}" class="size-full object-product-image" />
            {% endif %}
          </div>
          {% endif %}

          <div x-data="{ activeTab: 'description' }" class="mt-4">
            <div class="bg-white/[0.02] border border-white/[0.06] rounded-xl text-t-primary p-5 md:p-8">
              {% if product.product_tabs|length > 0 %}
                <div class="flex flex-wrap items-center gap-2 mb-6">
                  <button type="button" @click="activeTab = 'description'" class="px-4 py-2 whitespace-nowrap text-sm font-medium rounded-lg transition-all duration-200" :class="`${activeTab != 'description' ? 'text-t-primary/40 hover:text-t-primary hover:bg-white/[0.04]' : 'bg-accent-500/10 text-accent-500'}`">
                    Description
                  </button>
                  {% for productTab in product.product_tabs %}
                    <button type="button" @click="activeTab = '{{ productTab.slug }}'" class="px-4 py-2 whitespace-nowrap text-sm font-medium rounded-lg transition-all duration-200" :class="`${activeTab != '{{ productTab.slug }}' ? 'text-t-primary/40 hover:text-t-primary hover:bg-white/[0.04]' : 'bg-accent-500/10 text-accent-500'}`">
                      {{ productTab.title }}
                    </button>
                  {% endfor %}
                </div>
              {% endif %}
              <div>
                <template x-if="activeTab == 'description'">
                  <div class="text-t-primary/70 editor leading-relaxed">
                    {{ product.description | safe }}
                  </div>
                </template>
                {% for productTab in product.product_tabs %}
                  <template x-if="activeTab == '{{ productTab.slug }}'">
                    <div class="text-t-primary/70 editor leading-relaxed">
                      {{ productTab.content | safe }}
                    </div>
                  </template>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="lg:w-2/5">
        <div x-data="productForm" class="lg:sticky lg:top-8">
          <div class="bg-white/[0.02] border border-white/[0.06] rounded-xl overflow-hidden">
            <div class="text-t-primary p-5 md:p-6 border-b border-white/[0.06]">
              <div class="flex justify-between items-center">
                <div class="flex items-end gap-2">
                  <div class="text-3xl text-t-primary font-bold tracking-tight">
                    <span x-text="appCurrency.format(totalPrice, '{{ product.currency }}')"></span>
                  </div>
                  <div class="text-xs text-t-primary/30 mb-1">
                    <span x-text="appCurrency.format(unitPrice, '{{ product.currency }}')"></span>/pcs
                  </div>
                </div>
                <div class="text-xs text-t-primary/40">
                  {% if product.visibility == 'on_hold' %}
                    <span class="text-amber-400 font-medium">On Hold</span>
                  {% else %}
                    <div x-show="activeVariant in product.variants">
                      <span x-show="product.variants[activeVariant].stock > 0 || product.variants[activeVariant].stock === -1" class="text-t-primary/40">
                        <span x-show="product.variants[activeVariant].stock === -1" class="inline-flex items-center gap-1">
                          <svg xmlns="http://www.w3.org/2000/svg" class="text-accent-500 size-3" fill="currentColor" viewBox="0 0 256 256"><path d="M248,128a56,56,0,0,1-95.6,39.6l-.33-.35L92.12,99.55a40,40,0,1,0,0,56.9l8.52-9.62a8,8,0,1,1,12,10.61l-8.69,9.81-.33.35a56,56,0,1,1,0-79.2l.33.35,59.95,67.7a40,40,0,1,0,0-56.9l-8.52,9.62a8,8,0,1,1-12-10.61l8.69-9.81.33-.35A56,56,0,0,1,248,128Z"></path></svg>
                          In Stock
                        </span>
                        <span x-show="product.variants[activeVariant].stock > 0 && !product.hide_stock_count" x-text="product.variants[activeVariant].stock + ' In Stock'"></span>
                        <span x-show="product.variants[activeVariant].stock > 0 && product.hide_stock_count">In Stock</span>
                      </span>
                      <span x-show="product.variants[activeVariant].stock === 0" x-cloak class="text-red-400 font-medium">
                        Out of Stock
                      </span>
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
            
            {% render_snippet "product-form.njk", product=product %}

            {% if 'sales' in liveStats or 'views' in liveStats %}
              <div class="flex flex-col gap-3 sm:gap-2 border-t border-white/[0.06] text-xs text-t-primary/30 p-5 md:p-6">
                {% if 'views' in liveStats %}
                  <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-3.5 text-accent-500/60">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                    <p>
                      <span class="font-semibold text-t-primary/50">{{ liveStats.views }}</span>
                      {{ 'person is' if liveStats.views == 1 else 'people are' }} currently viewing this product.
                    </p>
                  </div>
                {% endif %}
                {% if 'sales' in liveStats %}
                  {% set salesCountHoursLabelMap = {
                    '1': 'hour',
                    '6': '6 hours',
                    '12': '12 hours',
                    '24': '24 hours',
                    '168': '7 days',
                    '720': '30 days'
                  } %}
                  <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-3.5 text-accent-500/60">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                    </svg>
                    <p>
                      <span class="font-semibold text-t-primary/50">{{ liveStats.sales }}</span>
                      {{ 'person has' if liveStats.sales == 1 else 'people have' }} purchased this product{{ '.' if not product.sales_count_hours in salesCountHoursLabelMap else (' in the last ' ~ salesCountHoursLabelMap[product.sales_count_hours] ~ '.') }}
                    </p>
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
    {% if productUpsells.length > 0 %}
      <div class="mt-8 lg:mt-12">
        <h2 class="text-lg font-bold text-t-primary mb-6 tracking-tight">
          Commonly Bought Together
        </h2>
        <div class="flex flex-wrap gap-4">
          {% set ogProduct = product %}
          {% for upsell in productUpsells %}
            <div class="w-full sm:w-[calc((100%-1rem)/2)] lg:w-[calc((100%-2rem)/3)] 2xl:w-[calc((100%-3rem)/4)]">
              {% render_snippet "product-card.njk", product=upsell %}
            </div>
          {% endfor %}
          {% set product = ogProduct %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% if 'latestOrders' in liveStats and liveStats.latestOrders|length > 0 %}
  <link href="https://cdn.jsdelivr.net/npm/flag-icons@7.3.2/css/flag-icons.min.css" rel="stylesheet" integrity="sha256-tyPeBlnZW2qWbAF1hQiCt9qo6SOgOSymvJBum+FrrwI=" crossorigin="anonymous">
  <div
    x-data="salesNotifications"
    x-cloak
    class="relative"
  >
    <div 
      x-show="show"
      x-transition:enter="transition-transform ease-in-out duration-500"
      x-transition:enter-start="transform translate-y-full"
      x-transition:enter-end="transform translate-y-0"
      x-transition:leave="transition-transform ease-in duration-500"
      x-transition:leave-start="transform translate-y-0"
      x-transition:leave-end="transform translate-y-full"
      class="fixed z-50 bottom-4 left-4 right-4 sm:right-auto"
    >
      <template x-if="order">
        <div class="flex items-center gap-3 p-2 border border-white/[0.08] bg-background/95 backdrop-blur-sm shadow-2xl rounded-xl group">
          {% if product.image_urls|length > 0 %}
            <div class="relative">
              <img src="{{ product.image_urls[0] }}" alt="{{ product.name }} image" class="size-12 object-cover rounded-lg sm:size-14">
            </div>
          {% endif %}
          <div class="truncate pr-3">
            <p class="text-xs text-t-primary/50 truncate">
              Someone
              <template x-if="order.country_code">
                <span>
                  from <i :class="`size-[0.625rem] sm:size-3 fi fi-${order.country_code.toLowerCase()}`"></i>
                </span>
              </template>
              purchased
            </p>
            <p class="text-sm text-t-primary font-medium truncate">
              {{ product.name }}
            </p>
            <p class="text-[0.65rem] text-t-primary/30 truncate">
              <span x-text="getTimeAgo(order.completed_at)"></span>
            </p>
          </div>
        </div>
      </template>
    </div>
  </div>

  <script>
    document.addEventListener('alpine:init', () => {
      Alpine.data('salesNotifications', () => ({
        displayTime: 8000,
        initTimeMin: 2000,
        initTimeMax: 4000,
        nextTimeMin: 8000,
        nextTimeMax: 12000,

        latestOrders: {{ liveStats.latestOrders | json }},
        show: false,

        get order() {
          return this.latestOrders.length > 0 ? this.latestOrders[0] : null;
        },

        getRandomInterval(min, max) {
          return Math.floor(Math.random() * (max - min + 1)) + min;
        },

        getTimeAgo(input) {
          const date = (input instanceof Date) ? input : new Date(input);
          const formatter = new Intl.RelativeTimeFormat('en');
          const ranges = {
            years: 3600 * 24 * 365,
            months: 3600 * 24 * 30,
            weeks: 3600 * 24 * 7,
            days: 3600 * 24,
            hours: 3600,
            minutes: 60,
            seconds: 1
          };
          const secondsElapsed = (date.getTime() - Date.now()) / 1000;
          for (let key in ranges) {
            if (ranges[key] < Math.abs(secondsElapsed)) {
              const delta = secondsElapsed / ranges[key];
              return formatter.format(Math.round(delta), key);
            }
          }

          return 'just now';
        },

        showNotification() {
          if (this.latestOrders.length === 0) return;

          this.show = true;
          setTimeout(() => {
            this.show = false;

            setTimeout(() => {
              this.latestOrders.shift();

              if (this.latestOrders.length > 0) {
                setTimeout(() => this.showNotification(), this.getRandomInterval(this.nextTimeMin, this.nextTimeMax));
              }
            }, 500);
          }, this.displayTime);
        },

        init() {
          setTimeout(() => this.showNotification(), this.getRandomInterval(this.initTimeMin, this.initTimeMax));
        }
      }));
    });
  </script>
{% endif %}

<script>
  window.addEventListener('load', () => {
    const arrows = {{ 'true' if product.image_urls|length > 1 else 'false' }};

    window.splideMain = new Splide('.splide.main', {
      type: 'slide',
      pagination: false,
      autoHeight: true,
      arrows
    });

    window.splideMain.mount();

    document.querySelectorAll('.splide__slide img').forEach((img) => {
      img.style.removeProperty('display');
    });
  });
</script>