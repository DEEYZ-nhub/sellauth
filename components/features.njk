<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="py-12 lg:py-16">
    {% if properties.title %}
      <div class="flex items-center justify-center mb-8 md:mb-12">
        <div class="inline-block text-center">
          <h2 class="text-t-primary text-2xl font-bold tracking-tight md:text-3xl lg:text-4xl text-balance">
            {{ properties.title | renderString }}
          </h2>
          <div class="w-12 h-0.5 bg-accent-500 mt-4 mx-auto rounded-full"></div>
        </div>
      </div>
    {% endif %}

    <div class="flex flex-wrap gap-4 w-full {{ 'justify-center' if properties.centered }}">
      {% for feature in properties.features %}
        <div class="w-full sm:w-[calc((100%-1rem)/2)] lg:w-[calc((100%-2rem)/3)] 2xl:w-[calc((100%-3rem)/4)]">
          <div class="text-center bg-white/[0.02] border border-white/[0.06] rounded-xl p-6 lg:p-8 transition-all duration-300 hover:bg-white/[0.04] hover:border-white/[0.1]">
            <div class="inline-flex items-center justify-center size-12 rounded-xl bg-accent-500/10 text-accent-500 mb-4">
              <i class="text-lg {{ feature.icon }}"></i>
            </div>
            <h4 class="mb-2 text-sm text-t-primary font-semibold uppercase tracking-wider lg:text-base">
              {{ feature.title | renderString }}
            </h4>
            <p class="text-xs font-normal text-t-primary/40 leading-relaxed lg:text-sm">
              <span class="whitespace-pre-line">{{ feature.description | renderString }}</span>
            </p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
