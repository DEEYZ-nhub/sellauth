<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="py-12 lg:py-16">
    {% if properties.title %}
      <div class="flex items-center justify-center mb-8 md:mb-12">
        <div class="inline-block text-center">
          <h2 class="text-t-primary text-2xl font-bold tracking-tight md:text-3xl lg:text-4xl text-balance">
            {{ properties.title | renderString }}
          </h2>
          <div class="w-12 h-0.5 bg-accent-500 mt-4 mx-auto rounded-full"></div>
        </div>
      </div>
    {% endif %}

    <div class="w-full grid grid-cols-2 gap-4 lg:grid-cols-4">
      <div class="text-center bg-white/[0.02] border border-white/[0.06] rounded-xl py-8 px-4 lg:py-10 transition-all duration-300 hover:bg-white/[0.04]">
        <p class="mb-2 text-3xl text-accent-500 font-bold md:text-4xl lg:text-5xl tracking-tight">
          {{ helpers.numbers.formatCompact(shop.products_sold) }}
        </p>
        <p class="text-xs font-medium uppercase tracking-widest text-t-primary/30 md:text-sm">
          Products Sold
        </p>
      </div>
      <div class="text-center bg-white/[0.02] border border-white/[0.06] rounded-xl py-8 px-4 lg:py-10 transition-all duration-300 hover:bg-white/[0.04]">
        <p class="mb-2 text-3xl text-accent-500 font-bold md:text-4xl lg:text-5xl tracking-tight">
          {{ helpers.numbers.formatCompact(shop.total_customers) }}
        </p>
        <p class="text-xs font-medium uppercase tracking-widest text-t-primary/30 md:text-sm">
          Total Customers
        </p>
      </div>
      <div class="text-center bg-white/[0.02] border border-white/[0.06] rounded-xl py-8 px-4 lg:py-10 transition-all duration-300 hover:bg-white/[0.04]">
        <p class="mb-2 text-3xl text-accent-500 font-bold md:text-4xl lg:text-5xl tracking-tight">
          {{ helpers.numbers.formatCompact(shop.total_feedbacks) }}
        </p>
        <p class="text-xs font-medium uppercase tracking-widest text-t-primary/30 md:text-sm">
          Reviews
        </p>
      </div>
      <div class="text-center bg-white/[0.02] border border-white/[0.06] rounded-xl py-8 px-4 lg:py-10 transition-all duration-300 hover:bg-white/[0.04]">
        <p class="mb-2 text-3xl text-accent-500 font-bold md:text-4xl lg:text-5xl tracking-tight">
          {{ helpers.numbers.formatDecimal(shop.average_rating) }}
        </p>
        <p class="text-xs font-medium uppercase tracking-widest text-t-primary/30 md:text-sm">
          Avg. Rating
        </p>
      </div>
    </div>
  </div>
</section>
