{
    "templates": {
        "shop": {
            "layout": "master",
            "components": {
                "hero": {
                    "type": "hero",
                    "properties": {
                        "title": "Discover Your Style",
                        "subtitle": "Premium quality products curated just for you",
                        "show_searchbar": true,
                        "buttons": [
                            {
                                "text": "Shop Now",
                                "icon": "fas fa-arrow-right",
                                "link": "\/products",
                                "new_tab": false,
                                "style": "regular"
                            }
                        ],
                        "alignment": "center",
                        "height": "medium",
                        "text_width": "medium",
                        "side_image": null
                    }
                },
                "products": {
                    "type": "products",
                    "properties": {
                        "title": "Featured Products",
                        "show_searchbar": false,
                        "ids": [],
                        "centered": false
                    }
                },
                "features": {
                    "type": "features",
                    "properties": {
                        "title": "Why Shop With Us",
                        "features": [
                            {
                                "title": "Fast Delivery",
                                "description": "Get your orders delivered quickly with our express shipping options.",
                                "icon": "fas fa-shipping-fast"
                            },
                            {
                                "title": "Secure Payments",
                                "description": "Shop with confidence using our encrypted payment gateway.",
                                "icon": "fas fa-lock"
                            },
                            {
                                "title": "Quality Products",
                                "description": "All products are carefully selected and quality tested.",
                                "icon": "fas fa-star"
                            },
                            {
                                "title": "24/7 Support",
                                "description": "Our customer service team is always here to help you.",
                                "icon": "fas fa-headset"
                            }
                        ],
                        "centered": false
                    }
                }
            },
            "components_order": [
                "hero",
                "products",
                "features"
            ]
        },
        "cart": {
            "layout": "master",
            "components": {
                "cart-page": {
                    "type": "cart-page",
                    "properties": []
                }
            },
            "components_order": [
                "cart-page"
            ]
        },
        "products": {
            "layout": "master",
            "components": {
                "products-page": {
                    "type": "products-page",
                    "properties": {
                        "default_title": "Our Products",
                        "category_title": "{{ category.name }} Products"
                    }
                }
            },
            "components_order": [
                "products-page"
            ]
        },
        "product": {
            "layout": "master",
            "components": {
                "product-page": {
                    "type": "product-page",
                    "properties": {
                        "variant_selector": "buttons",
                        "show_feedbacks": true,
                        "feedbacks_amount": 4,
                        "hide_add_to_cart": false,
                        "hide_buy_now": false
                    }
                }
            },
            "components_order": [
                "product-page"
            ]
        },
        "feedback": {
            "layout": "master",
            "components": {
                "feedbacks": {
                    "type": "feedbacks",
                    "properties": {
                        "title": "Customer Reviews",
                        "amount": null
                    }
                }
            },
            "components_order": [
                "feedbacks"
            ]
        },
        "status": {
            "layout": "master",
            "components": {
                "status-page": {
                    "type": "status-page",
                    "properties": []
                }
            },
            "components_order": [
                "status-page"
            ]
        },
        "faq": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "terms": {
            "layout": "master",
            "components": {
                "terms-page": {
                    "type": "terms-page",
                    "properties": []
                }
            },
            "components_order": [
                "terms-page"
            ]
        },
        "privacy-policy": {
            "layout": "master",
            "components": {
                "privacy-policy-page": {
                    "type": "privacy-policy-page",
                    "properties": []
                }
            },
            "components_order": [
                "privacy-policy-page"
            ]
        },
        "refund-policy": {
            "layout": "master",
            "components": {
                "refund-policy-page": {
                    "type": "refund-policy-page",
                    "properties": []
                }
            },
            "components_order": [
                "refund-policy-page"
            ]
        },
        "blog": {
            "layout": "master",
            "components": {
                "blog-posts": {
                    "type": "blog-posts",
                    "properties": {
                        "title": "Our Blog"
                    }
                }
            },
            "components_order": [
                "blog-posts"
            ]
        },
        "blog-post": {
            "layout": "master",
            "components": {
                "blog-post": {
                    "type": "blog-post-page",
                    "properties": []
                }
            },
            "components_order": [
                "blog-post-page"
            ]
        },
        "customer-dashboard": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "customer-invoices": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "customer-tickets": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "customer-ticket": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "customer-balance": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "customer-affiliate": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "maintenance": {
            "layout": "master",
            "components": [],
            "components_order": []
        }
    },
    "global": {
        "properties": {
            "accent_color": "#000000",
            "background_color": "#ffffff",
            "card_color": "#f8f8f8",
            "text_primary_color": "#000000",
            "text_accent_color": "#ffffff",
            "font": "Inter",
            "snow": false,
            "snow_color": "#ffffff",
            "product_card_image_aspect_ratio": "1\/1",
            "product_page_image_aspect_ratio": "4\/3",
            "product_image_fit": "cover",
            "group_card_image_aspect_ratio": "1\/1",
            "group_image_fit": "cover",
            "blog_card_image_aspect_ratio": "16\/9",
            "blog_image_fit": "cover"
        },
        "components": {
            "announcement": {
                "announcements": [
                    {
                        "text": "Free Shipping on Orders Over $50",
                        "link": null,
                        "new_tab": false
                    },
                    {
                        "text": "New Arrivals - Shop the Latest Collection",
                        "link": "\/products",
                        "new_tab": false
                    },
                    {
                        "text": "Limited Time: 15% Off Your First Order",
                        "link": null,
                        "new_tab": false
                    }
                ]
            },
            "navbar": {
                "show_shop_name": true,
                "show_logo": true,
                "links": [
                    {
                        "text": "Shop",
                        "link": "\/products",
                        "shape": "regular"
                    },
                    {
                        "text": "New",
                        "link": "\/products",
                        "shape": "regular"
                    },
                    {
                        "text": "Sale",
                        "link": "\/products",
                        "shape": "regular"
                    },
                    {
                        "text": "Reviews",
                        "link": "\/feedback",
                        "shape": "regular"
                    }
                ],
                "hide_currency_selector": false,
                "hide_customer_dashboard": false,
                "hide_cart": false
            },
            "footer": {
                "show_shop_name": true,
                "show_logo": false,
                "show_socials": true,
                "copyright": "Copyright \u00a9 {{ shop.name }} {{ '' | currentYear }}. All rights reserved.",
                "links": [
                    {
                        "text": "Terms",
                        "link": "\/terms-of-service",
                        "new_tab": false
                    },
                    {
                        "text": "Privacy",
                        "link": "\/privacy-policy",
                        "new_tab": false
                    },
                    {
                        "text": "Returns",
                        "link": "\/refund-policy",
                        "new_tab": false
                    }
                ]
            }
        }
    }
