{% set alignClassMap = {
  'left': '',
  'center': 'mx-auto',
  'right': 'ml-auto'
} %}

{% set alignClass = alignClassMap[alignment] %}

<div
  class="mb-4"
  x-data="{
    searchTerm: '',
    shouldShowItem(el) {
      return this.searchTerm === '' || decodeHtmlEntities(el.dataset.name.toLowerCase().toLowerCase()).includes(this.searchTerm.toLowerCase());
    },
    isModalOpen: false,
    openModal() {
      this.isModalOpen = true;
      document.body.style.overflow = 'hidden';

      setTimeout(() => {
        this.$refs.searchInput.focus();
      }, 100);
    },
    closeModal() {
      this.isModalOpen = false;
      document.body.style.overflow = 'auto';
    }
  }">
  <div class="bg-white/[0.02] border border-white/[0.06] rounded-xl overflow-hidden">
    <div class="flex items-center gap-4 max-w-xl text-t-primary/30 text-sm p-3.5 cursor-pointer transition-all duration-200 hover:bg-white/[0.02] focus-within:ring-2 focus-within:ring-accent-500/30 {{ alignClass }}" @click="openModal">
      <svg class="size-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
      </svg>
      <input type="text" class="bg-transparent cursor-pointer focus:outline-none placeholder:text-t-primary/30" placeholder="Search for products..." readonly />
    </div>
  </div>

  <div x-show="isModalOpen" class="fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-center justify-center min-h-screen px-4 text-center">
      <div x-cloak @click="closeModal" x-show="isModalOpen"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0" 
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100" 
        x-transition:leave-end="opacity-0"
        class="fixed inset-0 transition-opacity bg-black/60 backdrop-blur-sm" aria-hidden="true"
      ></div>

      <div x-cloak x-show="isModalOpen" 
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" 
        x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100" 
        x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        class="inline-block w-full max-w-[76rem] transition-all transform"
      >
        <div class="overflow-hidden text-t-primary text-left border border-white/[0.06] rounded-2xl bg-background p-6 md:p-8">
          <div class="flex items-center justify-between gap-4 mb-6">
            <div class="flex-1 flex items-center gap-4 bg-white/[0.02] border border-white/[0.06] rounded-xl text-t-primary/40 text-sm p-3.5 focus-within:border-accent-500/50 transition-colors duration-200 {{ alignClass }}">
              <svg class="size-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
              <input type="text" class="bg-transparent text-t-primary focus:outline-none placeholder:text-t-primary/30" placeholder="Search for products..." x-ref="searchInput" x-model="searchTerm">
            </div>

            <button @click="closeModal" class="flex items-center justify-center size-11 bg-white/[0.04] rounded-xl text-t-primary/40 transition-all duration-200 focus:outline-none hover:text-t-primary hover:bg-white/[0.08]">
              <svg class="size-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4" x-ref="productsContainer">
            {% for item in sortedItems %}
              {% if item.type != 'group' %}
                <div
                  x-show="shouldShowItem($el)"
                  x-transition
                  data-name="{{ item.name | lower | escape }}"
                >
                  {% render_snippet "product-card.njk", product=item %}
                </div>
              {% else %}
                {% for product in item.products %}
                  <div
                    x-show="shouldShowItem($el)"
                    x-transition
                    data-name="{{ product.name | lower | escape }}"
                  >
                    {% render_snippet "product-card.njk", product=product %}
                  </div>
                {% endfor %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
