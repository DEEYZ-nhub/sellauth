<a
  class="block h-full group"
  href="{{ 'javascript:void(0);' if product.type == 'group' else ( ('/product/' + product.path) | shopUrl ) }}"
  @click="{{ 'openGroupModal(' ~ product.id ~ ')' if product.type == 'group' else '' }}"
>
  <div class="h-full bg-white/[0.02] border border-white/[0.06] rounded-xl overflow-hidden text-t-primary transition-all duration-300 hover:bg-white/[0.04] hover:border-white/[0.1] hover:-translate-y-0.5">
    <div class="relative overflow-hidden">
      {% if product.image_urls|length > 0 %}
      <img src="{{ product.image_urls[0] }}" class="w-full {{ 'aspect-group-card-image object-group-image' if product.type == 'group' else 'aspect-product-card-image object-product-image' }}" loading="lazy" />
      {% elif product.image_url %}
      <img src="{{ product.image_url }}" class="w-full {{ 'aspect-group-card-image object-group-image' if product.type == 'group' else 'aspect-product-card-image object-product-image' }}" loading="lazy" />
      {% else %}
      <div class="flex justify-center items-center bg-white/[0.02] text-accent-500/30 {{ 'aspect-group-card-image' if product.type == 'group' else 'aspect-product-card-image' }}" />
        <svg xmlns="http://www.w3.org/2000/svg" class="size-16" viewBox="0 0 256 256">
          <path
            fill="currentColor"
            d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27ZM127 30.25a2 2 0 0 1 1.92 0L212.51 76l-33.94 18.57l-84.52-46.26ZM122 223l-83-45.43a2 2 0 0 1-1-1.75V86.66l84 46ZM43.49 76l38.07-20.85l84.51 46.26L128 122.24ZM218 175.82a2 2 0 0 1-1 1.75L134 223v-90.36l36-19.71V152a6 6 0 0 0 12 0v-45.63l36-19.71Z"
          />
        </svg>
      </div>
      {% endif %}
      {% if product.product_badges.card|length > 0 %}
        <div class="badges absolute top-3 left-3 flex items-center gap-2 flex-wrap">
          {% for productBadge in product.product_badges.card %}
            <div class="flex items-center gap-1.5 bg-accent-500 text-t-accent text-xs font-semibold px-2.5 py-1 rounded-md" style="background-color: {{ productBadge.color }}" data-text="{{ productBadge.label }}" data-color="{{ productBadge.color }}">
              {% if productBadge.icon %}
                <i class="{{ productBadge.icon }} fa-fw text-[0.65rem]"></i>
              {% endif %}
              {{ productBadge.label }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    <div class="p-4 lg:p-5">
      <h3 class="text-base font-semibold truncate mb-3 tracking-tight">
        {{ product.name }}
      </h3>
      <div class="flex items-center justify-between gap-2 mb-4">
        <p class="text-sm font-medium text-t-primary/40">
          <span class="text-accent-500">
            {% if product.min_price != product.max_price %}
              <span x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')">
                {{ formatPrice(product.min_price, product.currency) }}
              </span>
              -
              <span x-text="appCurrency.format({{ product.max_price }}, '{{ product.currency }}')">
                {{ formatPrice(product.max_price, product.currency) }}
              </span>
            {% elif product.min_price %}
              <span x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')">
                {{ formatPrice(product.min_price, product.currency) }}
              </span>
            {% else %}
              -
            {% endif %}
          </span>

          {% if product.min_price_slash and product.max_price_slash and product.min_price_slash != product.max_price_slash %}
            <span class="text-xs line-through text-t-primary/20 ml-1">
              <span x-text="appCurrency.format({{ product.min_price_slash }}, '{{ product.currency }}')">
                {{ formatPrice(product.min_price_slash, product.currency) }}
              </span>
              -
              <span x-text="appCurrency.format({{ product.max_price_slash }}, '{{ product.currency }}')">
                {{ formatPrice(product.max_price_slash, product.currency) }}
              </span>
            </span>
          {% elif product.min_price_slash %}
            <span class="text-xs line-through text-t-primary/20 ml-1">
              <span x-text="appCurrency.format({{ product.min_price_slash }}, '{{ product.currency }}')">
                {{ formatPrice(product.min_price_slash, product.currency) }}
              </span>
            </span>
          {% endif %}
        </p>
        <p class="text-xs text-t-primary/30">
          {% if product.type == 'group' %}
            {{ product.products | length }} Products
          {% else %}
            {% if product.stock === 0 %}
              <span class="text-red-400">Out of Stock</span>
            {% elif product.hide_stock_count %}
              In Stock
            {% elif product.stock === -1 %}
              <span class="inline-flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="text-accent-500 size-3" fill="currentColor" viewBox="0 0 256 256"><path d="M248,128a56,56,0,0,1-95.6,39.6l-.33-.35L92.12,99.55a40,40,0,1,0,0,56.9l8.52-9.62a8,8,0,1,1,12,10.61l-8.69,9.81-.33.35a56,56,0,1,1,0-79.2l.33.35,59.95,67.7a40,40,0,1,0,0-56.9l-8.52,9.62a8,8,0,1,1-12-10.61l8.69-9.81.33-.35A56,56,0,0,1,248,128Z"></path></svg>
                In Stock
              </span>
            {% else %}
              {{ product.stock + ' In Stock' }}
            {% endif %}
          {% endif %}
        </p>
      </div>
      <div class="flex items-center justify-center gap-2 text-sm text-accent-500 text-center font-medium rounded-lg px-4 py-2.5 bg-accent-500/5 transition-all duration-300 group-hover:bg-accent-500 group-hover:text-t-primary">
        View Details
        <svg class="size-4 transition-transform duration-300 group-hover:translate-x-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </div>
    </div>
  </div>
</a>
