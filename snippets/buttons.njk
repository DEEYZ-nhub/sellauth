{% for button in buttons %}
  {% if button.style == 'regular' %}
  {% set bClass = 'text-t-primary bg-accent-500 hover:bg-accent-600' %}
  {% elif button.style == 'outline' %}
  {% set bClass = 'text-t-primary/70 border-white/[0.12] hover:bg-white/[0.04] hover:text-t-primary hover:border-white/[0.2]' %}
  {% endif %}
  <a
    href="{{ (button.link | shopUrl) if button.link else '#' }}"
    target="{{ 'blank' if button.new_tab }}"
    class="inline-flex items-center gap-3 border px-6 py-3 text-sm font-medium rounded-lg transition-all ease-in-out duration-200 {{ bClass }}">
    {{ button.text | renderString }}
    {% if button.icon %}
    <i class="{{ button.icon }} fa-fw text-xs"></i>
    {% endif %}
  </a>
{% endfor %}
