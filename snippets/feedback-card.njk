<div x-data="{ expanded: false }" @click="() => expanded = !expanded" class="cursor-pointer">
  <div class="flex flex-col justify-between h-full bg-white/[0.02] border border-white/[0.06] rounded-xl text-t-primary transition-all duration-300 hover:bg-white/[0.04] hover:border-white/[0.1]">
    <div class="flex-1 text-left p-5">
      <div class="flex justify-between items-center mb-3">
        <div class="flex gap-0.5">
          {% for i in range(0, feedback.rating) %}
          <span class="text-accent-500">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
              <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
          </svg>
          </span>
          {% endfor %}
          {% for i in range(0, 5 - feedback.rating) %}
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 text-t-primary/15">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
          </svg>
          {% endfor %}
        </div>
        <span class="text-[0.65rem] text-t-primary/25">{{ feedback.created_at | formatDate }}</span>
      </div>
      <p class="text-sm text-t-primary/60 break-words leading-relaxed truncate" :class="{ 'truncate': !expanded }">
        {{ feedback.message }}
      </p>
      {% if feedback.reply %}
      <div class="mt-4 bg-white/[0.03] rounded-lg p-4">
        <p class="pl-3 text-sm text-t-primary/40 border-l-2 border-accent-500/50 break-words truncate leading-relaxed" :class="{ 'truncate': !expanded }">
          {{ feedback.reply }}
        </p>
        <p class="text-[0.65rem] text-right text-t-primary/25 mt-2">
          Reply from <span class="text-accent-500/70">{{ shop.name }}</span> at {{ feedback.replied_at | formatDate }}
        </p>
      </div>
      {% endif %}
    </div>
    <div class="px-5 py-3 text-xs text-t-primary/25 border-t border-white/[0.06] truncate">
      {% if feedback.items|length > 0 %}
        {{ feedback.items[0].name }}
        {% if feedback.items.length > 1 %}
          & {{ feedback.items.length - 1 }} more
        {% endif %}
      {% else %}
        Deleted Product
      {% endif %}
    </div>
  </div>
</div>
